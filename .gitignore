# ============================================================
# SE3020 — Smart Healthcare Platform
# .gitignore — covers Node.js, Python, Docker artifacts, OS
# ============================================================

# ---------- Node.js ----------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.pnpm-debug.log*
package-lock.json
# Uncomment when each developer has run npm install locally:
# !package-lock.json

# ---------- Build outputs ----------
dist/
build/
.next/
out/

# ---------- Environment variables (NEVER commit real .env) ----------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# DO commit .env.example
!.env.example

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.env/
*.egg-info/
dist/
build/
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
*.pyc

# ---------- Docker ----------
.docker/

# ---------- Kubernetes secrets (never commit real secrets) ----------
k8s/secret.yaml
# DO commit the example template:
!k8s/secret.yaml.example

# ---------- OS files ----------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---------- IDE / Editor ----------
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.history/

# ---------- Logs ----------
logs/
*.log

# ---------- Testing ----------
coverage/
.nyc_output/
junit.xml

# ---------- Cloudinary / Uploads (local dev) ----------
uploads/
tmp/

# ---------- Local reference docs / attached specs ----------
Assignment.md
FILE_1_PROJECT_KNOWLEDGE.md
FILE_2_MASTER_PROMPT.md
FILE_3_PERFORMANCE_PROMPT.md

