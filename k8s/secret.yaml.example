# ============================================================
# Kubernetes Secret — TEMPLATE ONLY (no real values)
#
# Usage:
#   1. Copy this file: cp k8s/secret.yaml.example k8s/secret.yaml
#   2. Fill in base64-encoded values:
#      echo -n "your-secret-value" | base64
#   3. Apply: kubectl apply -f k8s/secret.yaml
#   4. NEVER commit secret.yaml — it is in .gitignore
# ============================================================
apiVersion: v1
kind: Secret
metadata:
  name: app-secrets
  namespace: default
  labels:
    app: healthcare-platform
type: Opaque
data:
  # Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))" | base64
  JWT_SECRET: <base64-encoded-value>
  JWT_REFRESH_SECRET: <base64-encoded-value>

  # PostgreSQL credentials — must match APPOINTMENT_DB_URL and PAYMENT_DB_URL
  POSTGRES_USER: <base64-encoded-value>
  POSTGRES_PASSWORD: <base64-encoded-value>

  # Cloudinary — from https://cloudinary.com/ Dashboard → API Keys
  CLOUDINARY_CLOUD_NAME: <base64-encoded-value>
  CLOUDINARY_API_KEY: <base64-encoded-value>
  CLOUDINARY_API_SECRET: <base64-encoded-value>

  # Agora — from https://console.agora.io/
  AGORA_APP_ID: <base64-encoded-value>
  AGORA_APP_CERTIFICATE: <base64-encoded-value>

  # Stripe — from https://dashboard.stripe.com/developers/api-keys (test keys)
  STRIPE_SECRET_KEY: <base64-encoded-value>
  STRIPE_PUBLISHABLE_KEY: <base64-encoded-value>
  STRIPE_WEBHOOK_SECRET: <base64-encoded-value>

  # Twilio — from https://console.twilio.com/
  TWILIO_ACCOUNT_SID: <base64-encoded-value>
  TWILIO_AUTH_TOKEN: <base64-encoded-value>
  TWILIO_PHONE_NUMBER: <base64-encoded-value>

  # SendGrid — from https://app.sendgrid.com/
  SENDGRID_API_KEY: <base64-encoded-value>

  # Google Gemini — from https://aistudio.google.com/
  GEMINI_API_KEY: <base64-encoded-value>
