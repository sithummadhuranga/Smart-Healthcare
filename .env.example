# ============================================================
# SE3020 — Smart Healthcare Platform
# .env.example — ALL environment variable keys required
#
# INSTRUCTIONS:
#   cp .env.example .env
#   Fill in every blank value before running docker-compose up
#   NEVER commit the .env file (it is in .gitignore)
# ============================================================

# ============================================================
# JWT — Shared by Auth Service and API Gateway
# ============================================================
# Generate secure random strings: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ============================================================
# API Gateway — Port 3000
# ============================================================
API_GATEWAY_PORT=3000

# Upstream service URLs — use container names in Docker, localhost for local dev
AUTH_SERVICE_URL=http://auth-service:3001
PATIENT_SERVICE_URL=http://patient-service:3002
DOCTOR_SERVICE_URL=http://doctor-service:3003
APPOINTMENT_SERVICE_URL=http://appointment-service:3004
TELEMEDICINE_SERVICE_URL=http://telemedicine-service:3005
PAYMENT_SERVICE_URL=http://payment-service:3006
NOTIFICATION_SERVICE_URL=http://notification-service:3007
AI_SERVICE_URL=http://ai-symptom-service:8000

# CORS — allowed origins (comma-separated for multi-origin)
CORS_ORIGIN=http://localhost,http://localhost:3000,http://healthcare.local

# ============================================================
# Auth Service — Port 3001
# Auth Service uses its own authdb on the shared MongoDB instance
# ============================================================
AUTH_SERVICE_PORT=3001
AUTH_MONGODB_URI=mongodb://mongodb:27017/authdb

# ============================================================
# Patient Service — Port 3002
# ============================================================
PATIENT_SERVICE_PORT=3002
MONGODB_URI=mongodb://mongodb:27017/patientdb

# ============================================================
# Doctor Service — Port 3003
# ============================================================
DOCTOR_SERVICE_PORT=3003
DOCTOR_MONGODB_URI=mongodb://mongodb:27017/doctordb

# ============================================================
# Appointment Service — Port 3004
# NOTE: Ensure POSTGRES_USER and POSTGRES_PASSWORD below match this URL
# ============================================================
APPOINTMENT_SERVICE_PORT=3004
APPOINTMENT_DB_URL=postgresql://postgres:postgres@postgres:5432/appointmentdb

# ============================================================
# Telemedicine Service — Port 3005
# Register at: https://console.agora.io/
# Create a project → Enable "App Certificate" → copy App ID + Certificate
# ============================================================
TELEMEDICINE_SERVICE_PORT=3005
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# ============================================================
# Payment Service — Port 3006
# Stripe: https://dashboard.stripe.com/developers/api-keys (test keys only)
# Webhook secret: run `stripe listen --forward-to localhost:3006/api/payments/webhook`
# NOTE: Ensure POSTGRES_USER and POSTGRES_PASSWORD below match this URL
# ============================================================
PAYMENT_SERVICE_PORT=3006
PAYMENT_DB_URL=postgresql://postgres:postgres@postgres:5432/paymentdb
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ============================================================
# Notification Service — Port 3007
# Twilio: https://console.twilio.com/ — trial account, free credits
# SendGrid: https://app.sendgrid.com/ — 100 emails/day free
# ============================================================
NOTIFICATION_SERVICE_PORT=3007
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
SENDGRID_API_KEY=
FROM_EMAIL=noreply@healthcare.local

# ============================================================
# AI Symptom Checker — Port 8000 (Python FastAPI)
# Gemini: https://aistudio.google.com/ → Get API key (1M tokens/month free)
# ============================================================
AI_SERVICE_PORT=8000
GEMINI_API_KEY=

# ============================================================
# Cloudinary — Used by Patient Service for medical report uploads
# Register at: https://cloudinary.com/ → Dashboard → API Keys
# ============================================================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ============================================================
# PostgreSQL Database Credentials
# IMPORTANT: These must match the values in APPOINTMENT_DB_URL and PAYMENT_DB_URL above
# ============================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ============================================================
# MongoDB — Optional root auth (leave blank for local dev — no auth needed)
# If set, update ALL MongoDB URIs above to include credentials:
#   mongodb://<user>:<pass>@mongodb:27017/<dbname>?authSource=admin
# ============================================================
MONGO_INITDB_ROOT_USERNAME=
MONGO_INITDB_ROOT_PASSWORD=

# ============================================================
# RabbitMQ Credentials (default: guest/guest for local dev)
# IMPORTANT: Must match RABBITMQ_URL above
# ============================================================
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ============================================================
# Frontend — Port 80 (Docker) / 5173 (Vite dev server)
# IMPORTANT: Vite env vars MUST be prefixed with VITE_ to be exposed to the browser.
# In code access as: import.meta.env.VITE_API_URL
# These are bundled at BUILD TIME — rebuild the image if you change them.
# ============================================================
VITE_API_URL=http://localhost:3000
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_AGORA_APP_ID=
